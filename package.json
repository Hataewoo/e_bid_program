{
  "name": "cs-e-bid-program",
  "version": "1.1.0",
  "type": "module",
  "description": "Windows 전자입찰 분석 프로그램",
  "homepage": "https://github.com/Hataewoo/e_bid_program",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hataewoo/e_bid_program.git"
  },
  "main": "dist-electron/main.js",
  "author": "CS E-Bid Team",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:check": "npm run lint && npm run test && npm run regression:gate && npm run build",
    "build:renderer": "tsc && vite build",
    "prepare:packaging": "node scripts/prepare-packaging.mjs",
    "build:verify-packaging": "node scripts/verify-packaging.mjs",
    "build:prod": "npm run build:check && npm run prepare:packaging && electron-builder --win --x64",
    "build:prod:nsis": "npm run build:prod",
    "release:publish": "npm run build:check && npm run prepare:packaging && electron-builder --win --x64 --publish always",
    "build:prod:portable": "npm run build:check && npm run prepare:packaging && npm run build:renderer && electron-builder --win portable --x64",
    "electron:build": "npm run build:prod",
    "electron:build:portable": "npm run build:prod:portable",
    "preview": "vite preview",
    "lint": "eslint src tests electron",
    "lint:fix": "eslint src tests electron --fix",
    "test": "vitest run",
    "test:unit": "vitest run --exclude tests/integration/** --exclude tests/e2e/**",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "test:e2e:ci": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:headed": "npm run build && vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"tests/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"tests/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:prepare-dev": "prisma db push --skip-generate",
    "db:studio": "prisma studio",
    "catalog:import": "vite-node --config scripts/vite-node.config.ts scripts/import-legacy-catalog.ts",
    "catalog:diagnose": "vite-node --config scripts/vite-node.config.ts scripts/run-suite-diagnosis.ts",
    "regression:gate": "vite-node --config scripts/vite-node.config.ts scripts/run-regression-gate.ts",
    "postinstall": "prisma generate && npm run db:prepare-dev && node scripts/install-electron.mjs",
    "electron:install": "node scripts/install-electron.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.9.0",
    "ag-grid-community": "^33.3.0",
    "ag-grid-react": "^33.3.0",
    "electron-updater": "^6.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "react-router-dom": "^7.6.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "playwright": "^1.52.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.csebid.program",
    "productName": "CS E-Bid Analyzer",
    "copyright": "Copyright © 2026 CS E-Bid Team",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/@prisma/engines/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma/dev.db",
        "to": "database.db"
      },
      {
        "from": "node_modules/.prisma/client",
        "to": "prisma-client"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CS-E-Bid-Analyzer-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CS E-Bid Analyzer",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Hataewoo",
        "repo": "e_bid_program",
        "releaseType": "release"
      }
    ],
    "portable": {
      "artifactName": "CS-E-Bid-Analyzer-Portable-${version}-${arch}.${ext}"
    }
  }
}
